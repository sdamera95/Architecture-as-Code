            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION><ATTRIBUTE-DEFINITION-XHTML-REF>attr-text</ATTRIBUTE-DEFINITION-XHTML-REF></DEFINITION>
              <THE-VALUE><reqif-xhtml:div>Total system power draw shall not exceed battery discharge capacity.</reqif-xhtml:div></THE-VALUE>

      <SPEC-OBJECTS>
        <SPEC-OBJECT IDENTIFIER="req-mass" LAST-CHANGE="2026-05-14T08:00:00Z" LONG-NAME="MassBudget">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="REQ-001">
              <DEFINITION><ATTRIBUTE-DEFINITION-STRING-REF>attr-id</ATTRIBUTE-DEFINITION-STRING-REF></DEFINITION>

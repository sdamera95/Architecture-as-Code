# colcon build artifacts (in-place builds on the ROS2 box; build/ covered above)
# =============================================================================
install/
log/

# =============================================================================
# Reference ROS2 source repos (cloned for msg file ground truth)
# =============================================================================
references/
docs/

# =============================================================================

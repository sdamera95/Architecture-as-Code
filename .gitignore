# =============================================================================
# Operating system
# =============================================================================
.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Claude Code (per-project agent state)
#   .claude/      — settings.json, settings.local.json, hooks, agents, etc.
#   CLAUDE.md     — project memory; private, not for the public repo
#   *.jsonl       — conversation transcripts that Claude Code may write locally
# =============================================================================
.claude/
CLAUDE.md
*.jsonl

# =============================================================================
# Private research artifacts (not for the public repo)
#   manuscripts/   — paper drafts, audits, LaTeX sources
#   posters/       — conference posters
#   presentations/ — slide decks
#   docs/          — internal design notes
#   cowork/        — co-author working area
#   figures/       — figure source files (matches any figures/ dir at any depth)
# =============================================================================
manuscripts/
posters/
presentations/
docs/
cowork/
figures/


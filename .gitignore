# =============================================================================
# CATIA Magic binary project files (large; use Git LFS or share separately)
# =============================================================================
*.mdszip
*.zip

# =============================================================================
# Sysand environment and build output (reconstructible from lockfile / source)
# =============================================================================
sysand_env/
output/

# =============================================================================
# Bridge pipeline output (generated SysML v2 → ROS2 packages, per CLAUDE.md)
# =============================================================================
generated/

# =============================================================================
# Reference ROS2 source repos (cloned for msg file ground truth)
# =============================================================================
references/

# =============================================================================
# Doc-stripped SysML v2 figure-rendering siblings (generated by bridge/strip_docs.py)
# =============================================================================
*_viz.sysml

# =============================================================================
# Node / web tooling (catch-all if any subproject grows a JS frontend)
# =============================================================================
